# ═══════════════════════════════════════════════════════════════════
# Enterprise Intelligence Orchestrator (EIO) — Environment Config
# Copy this file to .env and fill in the values you want to use.
# ═══════════════════════════════════════════════════════════════════

# ─── LLM Provider ────────────────────────────────────────────────
# Choose ONE of the three options below.
# Change EIO_ACTIVE_LLM and uncomment the matching credentials.
# No code changes needed when switching providers.

# ┌─────────────────────────────────────────────────────────────┐
# │ OPTION A — GPT-OSS via HuggingFace  (FREE, no local GPU)   │
# │  • Create a free account at https://huggingface.co          │
# │  • Generate a token at huggingface.co/settings/tokens       │
# │  • Model used: openai/gpt-oss-20b (Apache-2.0)              │
# └─────────────────────────────────────────────────────────────┘
EIO_ACTIVE_LLM=gpt_oss
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — point to a HF Dedicated Endpoint instead of serverless:
# EIO_GPTOSS_ENDPOINT_URL=https://xxxx.us-east-1.aws.endpoints.huggingface.cloud
# EIO_GPTOSS_MODEL_ID=openai/gpt-oss-20b

# ┌─────────────────────────────────────────────────────────────┐
# │ OPTION B — OpenAI GPT-4o  (when API key is available)      │
# └─────────────────────────────────────────────────────────────┘
# EIO_ACTIVE_LLM=openai
# OPENAI_API_KEY=sk-...

# ┌─────────────────────────────────────────────────────────────┐
# │ OPTION C — Mock provider  (zero dependencies, always works) │
# │  Deterministic canned responses + real sentence embeddings. │
# │  Use for testing / CI / offline demo.                       │
# └─────────────────────────────────────────────────────────────┘
# EIO_ACTIVE_LLM=mock

# Anthropic Claude (stub — implement eio/connectors/llm/claude_provider.py)
# EIO_ACTIVE_LLM=anthropic
# ANTHROPIC_API_KEY=...

# IBM Granite via watsonx.ai (stub)
# EIO_ACTIVE_LLM=granite
# WATSONX_API_KEY=...
# WATSONX_PROJECT_ID=...
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─── Database Connector ──────────────────────────────────────────
# Active connector: sqlite | postgresql | sqlserver | snowflake | oracle | mysql | duckdb | databricks | db2
EIO_ACTIVE_DB=sqlite
EIO_SQLITE_PATH=eio/data/demo/financial.db

# PostgreSQL (uncomment to use)
# EIO_ACTIVE_DB=postgresql
# EIO_POSTGRES_URL=postgresql://user:pass@localhost:5432/eio

# Snowflake (uncomment to use)
# EIO_ACTIVE_DB=snowflake
# EIO_SNOWFLAKE_URL=snowflake://user:pass@account/db/schema?warehouse=WH

# ─── Storage Connector ───────────────────────────────────────────
# Active connector: local | s3 | azure_blob | gcs | ibm_cos | sharepoint | onedrive
EIO_ACTIVE_STORAGE=local
EIO_LOCAL_STORAGE_PATH=eio/data/demo/documents

# Amazon S3 (uncomment to use)
# EIO_ACTIVE_STORAGE=s3
# EIO_S3_BUCKET=my-eio-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# Azure Blob (uncomment to use)
# EIO_ACTIVE_STORAGE=azure_blob
# EIO_AZURE_CONNECTION_STRING=...
# EIO_AZURE_CONTAINER=eio-documents

# ─── Policy Engine ────────────────────────────────────────────────
EIO_POLICY_CONFIG=eio/core/policy/policies.yaml
EIO_POLICY_COST_LIMIT_USD=0.50
EIO_POLICY_TOKEN_BUDGET=16000

# ─── Vector Store (ChromaDB) ─────────────────────────────────────
EIO_CHROMA_PATH=eio/data/chroma
EIO_CHROMA_COLLECTION=eio_documents

# ─── API ─────────────────────────────────────────────────────────
EIO_API_HOST=0.0.0.0
EIO_API_PORT=8000
EIO_LOG_LEVEL=INFO

# ─── UI ──────────────────────────────────────────────────────────
EIO_API_URL=http://localhost:8000
