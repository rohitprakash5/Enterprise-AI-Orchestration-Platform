#   Agent Translate (Granite)    = 1bf8d13e-d252-485a-a5dd-8bfba9c60a92
#   BASISAssistant (SAP)         = e7890fb8-d38b-4b1a-a068-5bf195cb37ac
#   Generate User Persona        = 8a9c8368-8057-4c76-8e83-11c9dff8c1f7
#   Generate User Stories        = c0a9a0e2-6224-4a31-87b9-55f495525b74
#   Generate Test Cases          = 8970a835-0324-4305-8133-c5046f32b46d
